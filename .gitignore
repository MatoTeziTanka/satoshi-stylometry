__pycache__/
*.pyc
.venv/
venv/

# Prose corpora are reassembled from public sources by src/pull_corpus.py
# Do not commit redistributed text.
corpus/satoshi/*.txt
corpus/back/*.txt
corpus/szabo/*.txt
corpus/finney/*.txt
corpus/dai/*.txt
corpus/sassaman/*.txt
corpus/haber/*.txt
corpus/stornetta/*.txt

# Source-code corpora are reassembled at runtime via per-corpus pull
# instructions in code-corpus/<author>/SOURCE.md. NOTHING from a corpus
# directory should be committed except the SOURCE.md provenance file —
# this is the structural fix for both "redistribute source files we shouldn't"
# (restrictive licenses like TrueCrypt's) and the older per-extension whack-a-mole.
code-corpus/**/*
!code-corpus/
!code-corpus/*/
!code-corpus/**/SOURCE.md

# Keep dir structure
!corpus/.gitkeep
!corpus/*/.gitkeep

# Local
.DS_Store
*.swp
