__pycache__/
*.pyc
.venv/
venv/

# Prose corpora are reassembled from public sources by src/pull_corpus.py
# Do not commit redistributed text.
corpus/satoshi/*.txt
corpus/back/*.txt
corpus/szabo/*.txt
corpus/finney/*.txt
corpus/dai/*.txt
corpus/sassaman/*.txt
corpus/haber/*.txt
corpus/stornetta/*.txt

# Source-code corpora are reassembled by parallel pulls (see SOURCE.md
# in each directory). Same pattern as prose corpora.
code-corpus/*/*.c
code-corpus/*/*.h
code-corpus/*/*.cpp
code-corpus/*/*.cc
code-corpus/*/*.cxx
code-corpus/*/*.hpp
code-corpus/*/*.hxx
!code-corpus/*/SOURCE.md

# Keep dir structure
!corpus/.gitkeep
!corpus/*/.gitkeep

# Local
.DS_Store
*.swp
